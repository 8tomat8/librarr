LIBRARR_PORT=5050
LIBRARR_DB_PATH=/data/librarr.db

# qBittorrent
QB_URL=http://qbittorrent:8080
QB_USER=admin
QB_PASS=
QB_SAVE_PATH=/downloads
QB_CATEGORY=librarr
QB_AUDIOBOOK_SAVE_PATH=/audiobooks-incoming
QB_AUDIOBOOK_CATEGORY=audiobooks
QB_MANGA_SAVE_PATH=/manga-incoming
QB_MANGA_CATEGORY=manga

# Prowlarr (optional -- for torrent indexer search)
PROWLARR_URL=http://prowlarr:9696
PROWLARR_API_KEY=

# File Organization
FILE_ORG_ENABLED=true
EBOOK_DIR=/books/ebooks
AUDIOBOOK_DIR=/books/audiobooks
MANGA_DIR=/books/manga
INCOMING_DIR=/data/incoming
MANGA_INCOMING_DIR=/data/manga-incoming

# Torznab API
TORZNAB_API_KEY=              # Set this to a random string for Torznab API authentication

# Sources Registry — JSON registry of active indexers (see README).
# Leave both blank to use the embedded default registry.
LIBRARR_SOURCES_URL=             # e.g. https://raw.githubusercontent.com/JeremiahM37/librarr-sources/main/sources.json
LIBRARR_SOURCES_PATH=            # e.g. /data/sources.json
LIBRARR_SOURCES_REFRESH_MIN=0    # If > 0, re-fetch URL every N minutes

# Legacy per-source overrides — set to override values from the registry.
ANNAS_ARCHIVE_DOMAIN=

# Circuit Breaker
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_TIMEOUT=300

# Download Settings
MAX_RETRIES=2
RETRY_BACKOFF_SECONDS=60

# Search Filtering (torrent size bounds)
MIN_TORRENT_SIZE_BYTES=10000       # 10KB minimum
MAX_TORRENT_SIZE_BYTES=2000000000  # 2GB maximum

# Library Import Targets

# Calibre-Web (copy ebooks to Calibre library directory)
CALIBRE_LIBRARY_PATH=             # e.g. /books/calibre-library
CALIBRE_URL=                      # Optional: Calibre-Web URL for triggering tasks

# Audiobookshelf (trigger library scans after import)
ABS_URL=                          # e.g. http://audiobookshelf:13378
ABS_TOKEN=                        # API token for Audiobookshelf
ABS_LIBRARY_ID=                   # Audiobook library ID
ABS_EBOOK_LIBRARY_ID=             # Ebook library ID (if separate)

# Kavita (trigger library scans and copy files)
KAVITA_URL=                       # e.g. http://kavita:5000
KAVITA_USER=                      # Kavita username
KAVITA_PASS=                      # Kavita password
KAVITA_LIBRARY_PATH=              # Ebook library path for Kavita
KAVITA_MANGA_LIBRARY_PATH=        # Manga library path for Kavita

# Komga (manga/comic server)
KOMGA_URL=                        # e.g. http://komga:25600
KOMGA_USER=                       # Komga username
KOMGA_PASS=                       # Komga password
KOMGA_LIBRARY_ID=                 # Komga library ID for manga
KOMGA_LIBRARY_PATH=               # Local path to Komga library root

# Audiobookshelf public URL (for external links)
ABS_PUBLIC_URL=                   # e.g. https://abs.example.com

# Feature Toggles
RATE_LIMIT_ENABLED=true           # Enable per-IP rate limiting
METRICS_ENABLED=true              # Enable /metrics Prometheus endpoint
WEBNOVEL_ENABLED=true             # Enable web novel search sources
MANGADEX_ENABLED=true             # Enable MangaDex search source

# Public torrent-RSS driver (no auth)
TPB_ENABLED=false

# Authenticated forum/tracker driver (user supplies their own account)
BOOKTRACKER_URL=
BOOKTRACKER_USER=
BOOKTRACKER_PASS=
BOOKTRACKER_ENABLED=false

# OPDS-acquisition driver (user supplies the catalog URL)
FLIBUSTA_URL=
FLIBUSTA_ENABLED=false

# Library-card-style API driver (user supplies endpoint + account)
ZLIBRARY_URL=
ZLIBRARY_EMAIL=
ZLIBRARY_PASSWORD=
ZLIBRARY_ENABLED=false

# Search Filtering
# Multilingual driver results bypass this filter automatically.
# Only set to false if you want non-English results from English-focused sources too.
FOREIGN_LANG_FILTER=true          # Filter out non-English titles from English-focused sources

# lightnovel-crawler (for web novel EPUB generation)
LNCRAWL_CONTAINER=                # Docker container name for lightnovel-crawler

# Settings persistence
SETTINGS_FILE=/data/settings.json # Path to settings override file

# Authentication (optional — legacy single-user mode)
AUTH_USERNAME=                    # Username for web UI session auth (legacy, use multi-user registration instead)
AUTH_PASSWORD=                    # Password for web UI session auth (legacy, use multi-user registration instead)
API_KEY=                          # API key for programmatic access (X-Api-Key header or ?apikey= param)

# OIDC / SSO (optional)
OIDC_ENABLED=false                # Enable OIDC/SSO login
OIDC_PROVIDER_NAME=SSO            # Label for the login button (e.g. "Authentik", "Keycloak")
OIDC_ISSUER=                      # OIDC issuer URL (e.g. https://auth.example.com/application/o/librarr/)
OIDC_CLIENT_ID=                   # OIDC client ID
OIDC_CLIENT_SECRET=               # OIDC client secret
OIDC_REDIRECT_URI=                # Redirect URI (auto-detected if blank, e.g. http://librarr:5050/auth/oidc/callback)
OIDC_AUTO_CREATE_USERS=true       # Auto-create users on first OIDC login
OIDC_DEFAULT_ROLE=user            # Default role for OIDC-created users ("admin" or "user")
